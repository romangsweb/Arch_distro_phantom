// Zellij Layout — Dev Workspace
// nvim on left, terminal + git on right
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }
    tab name="code" focus=true {
        pane split_direction="vertical" {
            pane name="editor" size="60%" command="nvim" {
                args "."
            }
            pane split_direction="horizontal" {
                pane name="terminal" size="60%"
                pane name="git" command="lazygit"
            }
        }
    }
    tab name="server" {
        pane split_direction="vertical" {
            pane name="main"
            pane name="logs" command="journalctl" {
                args "-f" "--priority=err"
            }
        }
    }
}
